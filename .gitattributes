# 大文件走 Git LFS（IPA 单个可达 100MB+，超 GitHub 普通文件硬上限）
*.ipa filter=lfs diff=lfs merge=lfs -text
*.ipa binary

# ── GitHub Linguist：让语言统计反映“我们写的代码”(Rust)，而非第三方 C/C++ ──
# vendor 是第三方依赖(SDL/dynarmic/OpenAL/stb)，按文件数会盖过 Rust → 标 vendored 不计入
fresh-port/20-touchHLE-src/touchHLE/vendor/** linguist-vendored
# 游戏数据/资源(淘米版权，非我们的代码) → 不计入语言统计
fresh-port/01-cracked/** linguist-vendored
fresh-port/30-oldver/** linguist-vendored
# 逆向工具的机器生成产物(IDA / class-dump) → 标 generated，不计入
fresh-port/02-ida/** linguist-generated
fresh-port/03-objc/** linguist-generated
fresh-port/10-recomp/** linguist-generated
